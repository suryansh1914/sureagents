  "exports": {
    ".": "./index.ts",
    "./review": "./review.ts",
    "./annotate": "./annotate.ts",
    "./remote": "./remote.ts",
    "./browser": "./browser.ts",
    "./goal-setup": "./goal-setup.ts",
    "./storage": "./storage.ts",
    "./git": "./git.ts",
    "./p4": "./p4.ts",
    "./vcs": "./vcs.ts",
    "./repo": "./repo.ts",
    "./review-workspace": "./review-workspace.ts",
    "./share-url": "./share-url.ts",
